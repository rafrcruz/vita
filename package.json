{
  "name": "vita",
  "version": "0.1.0",
  "private": true,
  "description": "VITA — Personal Health Observability Platform",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "npm -w @vita/api run dev",
    "dev:web": "npm -w @vita/web run dev",
    "build": "npm -w @vita/shared run build && npm -w @vita/api run build && npm -w @vita/web run build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "db:generate": "npm -w @vita/api run db:generate",
    "db:migrate": "npm -w @vita/api run db:migrate"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "concurrently": "^9.1.0",
    "drizzle-orm": "^0.45.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^15.13.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9"
  }
}
