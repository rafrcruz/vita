# ============================================================================
# VITA — variáveis de ambiente (exemplo). Copie para .env e preencha.
# NUNCA commite o .env (já ignorado pelo Git). Em produção use Vercel Env Vars.
# ============================================================================

# --- Núcleo (necessário desde o MVP) ---
NODE_ENV=development
# Porta local do backend (Express)
PORT=3001
# Origem do frontend (usada para CORS, cookies e redirect do OAuth)
WEB_ORIGIN=http://localhost:5173
# Segredo para assinar o JWT de sessão (gerar: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))")
JWT_SECRET=
# Nome do cookie de sessão
SESSION_COOKIE_NAME=vita_session

# --- Banco de dados (necessário a partir da US2 — Neon) ---
# Ex.: postgresql://user:pass@ep-xxx.neon.tech/vita?sslmode=require
DATABASE_URL=

# --- Autenticação Google (necessário a partir da US3) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:5173/api/auth/google/callback
# E-mails do(s) administrador(es) inicial(is), separados por vírgula
ADMIN_EMAILS=

# --- Observabilidade (necessário a partir da US4 — Sentry) ---
SENTRY_DSN=
# DSN público do frontend (exposto no bundle; configurar no apps/web)
VITE_SENTRY_DSN=
# Token pessoal do usuário Sentry (acesso admin geral)
SENTRY_PERSONAL_TOKEN=
# Token de integração/release do Sentry (CI e source maps; escopo org:ci)
SENTRY_AUTH_TOKEN=

