{
  "name": "@vita/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npm run db:migrate && tsc -p tsconfig.json --noEmit && esbuild api/index.ts --bundle --platform=node --target=node22 --format=esm --external:express --external:cors --external:cookie-parser --external:helmet --external:dotenv --external:drizzle-orm --external:@sentry/node --external:@neondatabase/serverless --external:google-auth-library --external:jose --external:pino --external:pino-http --external:swagger-ui-express --external:zod --external:@asteasolutions/zod-to-openapi --outfile=api/index.js",
    "start": "tsx src/server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.0",
    "@neondatabase/serverless": "^0.10.4",
    "@sentry/node": "^8.47.0",
    "@vita/shared": "*",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "google-auth-library": "^9.15.0",
    "helmet": "^8.2.0",
    "jose": "^5.9.6",
    "pino": "^10.3.1",
    "pino-http": "^10.3.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.7",
    "drizzle-kit": "^0.31.10",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
