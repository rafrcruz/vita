{
  "name": "@vita/api",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npm run db:migrate && tsc -p tsconfig.json --noEmit && npm run bundle",
    "bundle": "esbuild api/index.ts --bundle --platform=node --target=node22 --format=esm --external:express --external:cors --external:cookie-parser --external:helmet --external:dotenv --external:drizzle-orm --external:@sentry/node --external:@neondatabase/serverless --external:google-auth-library --external:jose --external:pino --external:pino-http --external:swagger-ui-express --external:zod --external:@asteasolutions/zod-to-openapi --external:csurf --external:express-rate-limit --outfile=api/index.js",
    "start": "tsx src/server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.0",
    "@neondatabase/serverless": "^0.10.4",
    "@sentry/node": "^10.58.0",
    "@vita/shared": "*",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csurf": "^1.11.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.7.0",
    "helmet": "^8.2.0",
    "jose": "^6.2.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.19",
    "@types/csurf": "^1.11.5",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.7",
    "drizzle-kit": "^0.31.10",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
