{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["vite/client", "vitest/globals", "@testing-library/jest-dom"],
    "noEmit": true,
    "paths": {
      "@vita/shared": ["../../packages/shared/src/index.ts"],
      "@vita/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src"]
}
